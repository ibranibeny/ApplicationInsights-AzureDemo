{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Demo environment for Azure Monitor and Application Insights, hosted on Azure Container Instances (ACI). This subscription has App Service dedicated-worker VM quota = 0, so the web app runs as a container on ACI (separate quota) pulling its image from an Azure Container Registry.",
    "deploymentOrder": "ACI cannot pull an image that does not exist yet. Deploy in two phases: (1) deploy with deployContainerGroup=false to create the registry + monitoring; (2) build & push the image: 'az acr build --registry <acr> --image webdemo:latest azure-monitor-demo/src/web'; (3) deploy again with deployContainerGroup=true to create the running container."
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "defaultValue": "demo-monitor",
      "metadata": {
        "description": "Name of the environment"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Primary location for all resources"
      }
    },
    "containerImageRepository": {
      "type": "string",
      "defaultValue": "webdemo:latest",
      "metadata": {
        "description": "Repository and tag of the image inside the ACR (e.g. webdemo:latest). The image must be pushed via 'az acr build' before the container group is created."
      }
    },
    "containerCpu": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Number of vCPUs for the container"
      }
    },
    "containerMemoryInGb": {
      "type": "string",
      "defaultValue": "1.5",
      "metadata": {
        "description": "Memory in GB for the container"
      }
    },
    "deployContainerGroup": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Set to false on the first deployment (registry + monitoring only), then true after the image has been pushed to ACR."
      }
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().id, parameters('environmentName'), parameters('location')))]",
    "tags": {
      "azd-env-name": "[parameters('environmentName')]",
      "purpose": "azure-monitor-demo"
    },
    "logAnalyticsWorkspaceName": "[concat('log-', variables('resourceToken'))]",
    "applicationInsightsName": "[concat('appi-', variables('resourceToken'))]",
    "containerRegistryName": "[concat('acr', variables('resourceToken'))]",
    "containerGroupName": "[concat('appi-demo-web-', variables('resourceToken'))]",
    "dnsNameLabel": "[concat('appi-demo-', variables('resourceToken'))]",
    "regionFqdnSegment": "[replace(toLower(parameters('location')), ' ', '')]",
    "containerImage": "[concat(variables('containerRegistryName'), '.azurecr.io/', parameters('containerImageRepository'))]",
    "containerPort": 8080
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30,
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "kind": "web",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('containerRegistryName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "condition": "[parameters('deployContainerGroup')]",
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('containerGroupName')]",
      "location": "[parameters('location')]",
      "tags": "[union(variables('tags'), createObject('azd-service-name', 'web'))]",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]",
        "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]"
      ],
      "properties": {
        "sku": "Standard",
        "osType": "Linux",
        "restartPolicy": "Always",
        "imageRegistryCredentials": [
          {
            "server": "[concat(variables('containerRegistryName'), '.azurecr.io')]",
            "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2023-07-01').username]",
            "password": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2023-07-01').passwords[0].value]"
          }
        ],
        "ipAddress": {
          "type": "Public",
          "dnsNameLabel": "[variables('dnsNameLabel')]",
          "ports": [
            {
              "protocol": "TCP",
              "port": "[variables('containerPort')]"
            }
          ]
        },
        "containers": [
          {
            "name": "web",
            "properties": {
              "image": "[variables('containerImage')]",
              "ports": [
                {
                  "protocol": "TCP",
                  "port": "[variables('containerPort')]"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": "[parameters('containerCpu')]",
                  "memoryInGB": "[float(parameters('containerMemoryInGb'))]"
                }
              },
              "environmentVariables": [
                {
                  "name": "ASPNETCORE_URLS",
                  "value": "[concat('http://+:', string(variables('containerPort')))]"
                },
                {
                  "name": "ASPNETCORE_ENVIRONMENT",
                  "value": "Production"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secureValue": "[reference(resourceId('Microsoft.Insights/components', variables('applicationInsightsName')), '2020-02-02').ConnectionString]"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "High Response Time Alert",
      "location": "global",
      "tags": "[variables('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]"
      ],
      "properties": {
        "description": "Alert when average server response time exceeds 5 seconds",
        "severity": 2,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "ResponseTime",
              "metricName": "requests/duration",
              "dimensions": [],
              "operator": "GreaterThan",
              "threshold": 5000,
              "timeAggregation": "Average",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "autoMitigate": true
      }
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "High Error Rate Alert",
      "location": "global",
      "tags": "[variables('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]"
      ],
      "properties": {
        "description": "Alert when the number of failed requests exceeds 10 in the window",
        "severity": 1,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "FailedRequests",
              "metricName": "requests/failed",
              "dimensions": [],
              "operator": "GreaterThan",
              "threshold": 10,
              "timeAggregation": "Total",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "autoMitigate": true
      }
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[concat('http://', variables('dnsNameLabel'), '.', variables('regionFqdnSegment'), '.azurecontainer.io:', string(variables('containerPort')))]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[concat(variables('containerRegistryName'), '.azurecr.io')]"
    },
    "containerRegistryName": {
      "type": "string",
      "value": "[variables('containerRegistryName')]"
    },
    "applicationInsightsName": {
      "type": "string",
      "value": "[variables('applicationInsightsName')]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "value": "[variables('logAnalyticsWorkspaceName')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    }
  }
}
